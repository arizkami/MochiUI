{
  "name": "@spherekit/vue",
  "version": "2026.05.09-alpha.1",
  "description": "Vue wrapper for SphereEngine",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --format=esm && tsc -p tsconfig.build.json",
    "bundle": "bun build src/index.ts --outfile bundle.js --format=esm --target=bun",
    "bundle:demo": "bun run build-demo.ts"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.22",
    "@vue/reactivity": "^3.5.22",
    "@vue/runtime-core": "^3.5.22",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
