{
  "name": "@spherekit/react",
  "description": "React wrapper for SphereEngine",
  "version": "2026.05.09-alpha.1",
  "type": "module",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --format=esm && tsc -p tsconfig.build.json",
    "bundle": "bun build src/index.ts --outfile bundle.js --format=esm --target=bun",
    "bundle:demo": "bun build examples/App.tsx --outfile ../../example/ReactUI/bundle.js --format=iife --target=node --minify-whitespace"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "^0.33.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-reconciler": "^0.33.0"
  }
}
