# Local SphereEngine build settings.
# Copy this file to .env and adjust paths for your machine.

# Visual Studio install root or vcvars64.bat path.
# VS_PATH=C:\Program Files\Microsoft Visual Studio\18\Community
VS_PATH=

# Build/prebuilt behavior.
USE_PREBUILT=ON
FETCH_PREBUILT=ON
PREBUILT_DIR=external/prebuilt

# Optional dependency overrides.
SKIA_DIR=
V8_DIR=
SKIA_URL=
V8_URL=

# CMake/Bun orchestration.
BUILD_DIR=build
CMAKE_BUILD_TYPE=Release
CMAKE_GENERATOR=Ninja
CMAKE_PATH=cmake
BUN_INSTALL_MODULES=ON
FETCH_SUBMODULES=ON
